<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- NOT sandboxed, on purpose. This app ships via Developer ID + notarization
       (not the Mac App Store), so App Sandbox is not required — and it BREAKS
       the native file picker: a sandboxed app brokers NSOpenPanel through
       Powerbox, which returns nil here and SIGABRTs the rfd file dialog
       (objc2 retain_semantics::none_fail). Notarization needs the HARDENED
       RUNTIME (the cs.* entitlements below + `codesign --options runtime`),
       which is a different thing from the sandbox. `com.apple.security.app-sandbox`
       was removed for this reason — do not re-add it (added 00460d8 by mistake,
       conflating sandbox with hardened runtime). -->

  <!-- Network access for API and WebSocket connections -->
  <key>com.apple.security.network.client</key>
  <true/>

  <!-- Hardened Runtime: allow the WKWebView / WebKit JIT (required by Tauri) -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>

  <!-- Allow unsigned executable memory (required by WebKit JIT) -->
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>

  <!-- NOTE: APNs (aps-environment) is intentionally NOT declared here.
       This Entitlements.plist is applied to BOTH iOS and macOS desktop
       builds via bundle.macOS.entitlements in tauri.conf.json. The
       Forward Email LLC Developer ID Application certificate (used for
       macOS distribution) is not authorized for APNs, so embedding
       aps-environment caused the macOS launch-time entitlement check
       to fail with "CODESIGNING 1 Taskgated Invalid Signature" even
       though codesign + notarization succeeded at build time.

       For iOS, scripts/inject-ios-signing.cjs inserts the right
       aps-environment value ("development" or "production") into this
       file just before xcodebuild runs. Desktop builds never run that
       script, so the entitlement stays absent for macOS distribution. -->
</dict>
</plist>
