<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!--
    macOS TCC ("Files and Folders") usage descriptions. This app is NOT
    sandboxed (see Entitlements.plist), so saving an email attachment into a
    protected user folder requires these keys: macOS shows the string in the
    permission prompt the first time we write there, and grants access once the
    user approves. Without them the write is silently denied and the save fails.
    Tauri merges this file into the generated macOS bundle Info.plist.
    These only prompt on a real user-initiated save, never at launch.
  -->
  <key>NSDownloadsFolderUsageDescription</key>
  <string>Forward Email needs access to your Downloads folder to save email attachments there.</string>
  <key>NSDocumentsFolderUsageDescription</key>
  <string>Forward Email needs access to your Documents folder to save email attachments there.</string>
  <key>NSDesktopFolderUsageDescription</key>
  <string>Forward Email needs access to your Desktop folder to save email attachments there.</string>
</dict>
</plist>
