{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "types": ["node"],
    "baseUrl": "."
  },
  "include": ["vitest.config.ts", "specs/**/*.ts", "support/**/*.ts", "setup/**/*.ts"],
  "exclude": ["node_modules", "reports", "screenshots"]
}
